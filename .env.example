# -------- Application --------
APP_NAME=CipherLink
ENVIRONMENT=development
DEBUG=true

# -------- Backend API --------
API_HOST=0.0.0.0
API_PORT=8000

# -------- PostgreSQL --------
POSTGRES_USER=cipherlink
POSTGRES_PASSWORD=cipherlink
POSTGRES_DB=cipherlink
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# Optional override. If set, this is used directly by SQLAlchemy.
DATABASE_URL=postgresql+psycopg://cipherlink:cipherlink@localhost:5432/cipherlink

# -------- CORS --------
# JSON list format for pydantic-settings parsing
CORS_ORIGINS=["http://localhost:5173"]

# -------- Frontend --------
VITE_API_BASE_URL=/api
VITE_BACKEND_PROXY_TARGET=http://localhost:8000
